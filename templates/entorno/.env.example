#############################################
# WEBPARAMASCOTAS - PLANTILLA DE VARIABLES
#############################################
#
# USO RECOMENDADO:
# - Copiar a entorno/.env solo por los scripts de deploy.
# - El modo real del servidor vive en ENTORNO_MODE dentro de entorno/.env.
#
# Comando:
#   ./scripts/deploy.sh
#
# PARAMETROS QUE PUEDEN VARIAR Y PARA QUE SIRVEN:
#
# ENTORNO_MODE / APP_ENV
#   qa         -> ambiente QA; los guardrails fuerzan SRI pruebas y segmento test
#   production -> ambiente productivo; los guardrails fuerzan SRI produccion
ENTORNO_MODE=qa
APP_ENV=qa

# COMPOSE_PROFILES
#   Perfil activo de docker compose. En QA usa runtime estable; en produccion usa build optimizado.
COMPOSE_PROFILES=qa

# PORT
#   Puerto publico del frontend en tu maquina.
PORT=3000

# FRONTEND_WORKERS
#   Procesos Node que comparten el listener del bundle Next standalone.
#   4 es el valor operativo por defecto; rango permitido: 1..16.
FRONTEND_WORKERS=4

# SITE_DOMAIN
#   Dominio canonico del proyecto.
SITE_DOMAIN=paramascotasec.com

# SITE_WWW_DOMAIN
#   Alias www del dominio principal.
SITE_WWW_DOMAIN=www.paramascotasec.com

# SITE_ALIASES
#   Aliases publicos separados por coma. Normalmente incluye SITE_WWW_DOMAIN.
SITE_ALIASES=www.paramascotasec.com

# SITE_PUBLIC_IP
#   IP publica real del servidor cuando aplique.
SITE_PUBLIC_IP=160.153.181.23

# SITE_LOCAL_IPS
#   IPs locales/LAN donde desarrollas o validas por hosts.
SITE_LOCAL_IPS=192.168.100.229,80.241.213.31,192.168.40.229

# FRONTEND_QA_RUNTIME
#   stable -> build + start dentro del contenedor webparamascotas.
#             Recomendado si navegas por el gateway o una URL de dominio.
#   hot    -> next dev con hot reload.
#             Usarlo solo como herramienta local explicita fuera del deploy del ambiente.
FRONTEND_QA_RUNTIME=stable
FRONTEND_QA_BUNDLER=webpack

# API_FETCH_TIMEOUT_MS
#   Tiempo maximo de espera en ms para llamadas frontend -> backend.
API_FETCH_TIMEOUT_MS=15000

# NEXT_PUBLIC_BASE_URL
#   URL base publica del frontend (visible en navegador).
#   En QA con dominio real por hosts conviene usar https://paramascotasec.com.
NEXT_PUBLIC_BASE_URL=https://paramascotasec.com

# NEXT_PUBLIC_SITE_DOMAIN / NEXT_PUBLIC_SITE_ALIASES / NEXT_PUBLIC_SITE_LOCAL_IPS
#   Dominio canonico, aliases e IPs locales que Next acepta para dev origins y metadata.
NEXT_PUBLIC_SITE_DOMAIN=paramascotasec.com
NEXT_PUBLIC_SITE_ALIASES=www.paramascotasec.com
NEXT_PUBLIC_SITE_LOCAL_IPS=192.168.100.229,80.241.213.31,192.168.40.229

# NEXT_PUBLIC_TENANT_SLUG / NEXT_PUBLIC_API_SERVICE_SEGMENT / NEXT_PUBLIC_API_BASE_PATH
#   Prefijo publico tenantizado que APISIX expone para el backend.
NEXT_PUBLIC_TENANT_SLUG=paramascotasec
NEXT_PUBLIC_API_SERVICE_SEGMENT=api
NEXT_PUBLIC_API_BASE_PATH=/paramascotasec/api

# NEXT_PUBLIC_BACKEND_URL
#   URL del backend usada por peticiones desde el navegador.
#   Normalmente debe ir por el mismo dominio del gateway.
NEXT_PUBLIC_BACKEND_URL=https://paramascotasec.com/paramascotasec/api

# NEXT_PUBLIC_AUTH_CSRF_COOKIE_NAME
#   Nombre de la cookie no-httpOnly usada para enviar cabecera CSRF en requests mutantes.
NEXT_PUBLIC_AUTH_CSRF_COOKIE_NAME=pm_csrf_ecommerce

# QA conserva escritura local y URLs /uploads/*. Produccion o REQUIRE_HA=true
# exigen backend-object-storage; Next nunca recibe credenciales S3.
REQUIRE_HA=false
PRODUCT_IMAGE_UPLOAD_MODE=local
UPLOAD_BACKEND_TIMEOUT_MS=30000
# Nombre completo de la cookie CSRF del canal Dashboard. Debe terminar en _dashboard
# y coincidir con AUTH_CSRF_COOKIE_NAME + sufijo de superficie del backend.
DASHBOARD_AUTH_CSRF_COOKIE_NAME=pm_csrf_dashboard
# URL publica HTTPS del CDN/object storage, igual a OBJECT_STORAGE_PUBLIC_BASE_URL
# del backend. Se requiere con backend-object-storage.
NEXT_PUBLIC_UPLOADS_BASE_URL=

# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY
#   Llave publica de Google Maps usada por el mapa del checkout y direcciones del panel.
#   En Google Cloud debe estar restringida por HTTP referrer al dominio publico.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# BACKEND_URL_INTERNAL
#   URL interna para peticiones servidor a servidor desde el contenedor de Next.js.
#   Mantener nombre de servicio Docker para evitar dependencia de IP.
BACKEND_URL_INTERNAL=http://backend-http:8080/api

# STOREFRONT_BACKEND_PROXY_TOKEN
#   Secreto exclusivo del salto Next.js -> backend; APISIX y Dashboard no lo reciben.
#   El deploy lo escribe en entorno/.secrets/storefront_backend_proxy_token con permisos 600
#   y Docker Compose lo monta como secret dentro del contenedor.
STOREFRONT_BACKEND_PROXY_TOKEN=replace-with-dedicated-storefront-backend-proxy-token

# PANEL_IP_MODE
#   off     -> sin restriccion IP para deep links administrativos de /my-account
#   private -> permite loopback + redes privadas RFC1918
#   custom  -> usa solo PANEL_IP_ALLOWLIST
#   El panel de cliente en /my-account no debe quedar bloqueado por IP.
PANEL_IP_MODE=private

# PANEL_IP_ALLOWLIST
#   Lista opcional de IPs/CIDR adicionales.
#   En modo private se suman a las privadas.
#   En modo custom se convierten en la lista efectiva.
PANEL_IP_ALLOWLIST=

# Ejemplo rapido para PRODUCCION:
# APP_ENV=production
# COMPOSE_PROFILES=production
# NEXT_PUBLIC_BASE_URL=https://paramascotasec.com
# NEXT_PUBLIC_BACKEND_URL=https://paramascotasec.com/paramascotasec/api
