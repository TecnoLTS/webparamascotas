{
  "name": "ParaMascotasEC",
  "version": "0.2.0",
  "private": true,
  "packageManager": "npm@11.16.0",
  "engines": {
    "node": ">=22.11.0 <27"
  },
  "scripts": {
    "images:convert-webp": "node ./scripts/convert-jpg-assets-to-webp.mjs",
    "images:home-performance": "node ./scripts/generate-home-performance-images.mjs",
    "images:manifest": "node ./scripts/generate-image-version-manifest.mjs",
    "images:upload-variants": "node ./scripts/generate-upload-image-variants.mjs",
    "predev": "npm run images:manifest",
    "prebuild": "npm run images:home-performance && npm run images:upload-variants && npm run images:manifest",
    "prestart": "npm run images:manifest",
    "prelint": "npm run images:manifest",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "api:contracts:check": "node ./scripts/check-api-contract-usage.mjs",
    "lint": "eslint . --max-warnings=0",
    "seo:audit": "node ./scripts/audit-seo-merchant.mjs",
    "capabilities:generate": "node ../scripts/generate-system-capabilities.mjs --write --workspace ../..",
    "capabilities:check": "node ../scripts/generate-system-capabilities.mjs --check --workspace ../..",
    "typecheck": "tsc --noEmit --pretty false",
    "test": "npm run capabilities:check && npm run api:contracts:check && npm run lint && npm run typecheck",
    "deploy": "../scripts/deploy.sh"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "@tailwindcss/postcss": "^4.3.0",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.17.0",
    "next": "^16.2.7",
    "nprogress": "^0.2.0",
    "rc-slider": "^11.1.9",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-fast-marquee": "^1.6.5",
    "react-paginate": "^8.3.0",
    "react-slick": "^0.31.0",
    "sass": "^1.100.0",
    "sharp": "^0.34.5",
    "slick-carousel": "^1.8.1",
    "swiper": "^12.2.0",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "^16.2.7",
    "@types/node": "24.12.4",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/react-slick": "^0.23.13",
    "eslint": "^10.4.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "postcss": "8.5.15",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0"
  },
  "overrides": {
    "postcss": "8.5.15"
  },
  "allowScripts": {
    "@parcel/watcher": true,
    "sharp": true
  }
}
