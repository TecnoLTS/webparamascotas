{
  "name": "ParaMascotasEC",
  "version": "0.2.0",
  "private": true,
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "images:convert-webp": "node ./scripts/convert-jpg-assets-to-webp.mjs",
    "images:home-performance": "node ./scripts/generate-home-performance-images.mjs",
    "images:manifest": "node ./scripts/generate-image-version-manifest.mjs",
    "images:upload-variants": "node ./scripts/generate-upload-image-variants.mjs",
    "predev": "npm run images:manifest",
    "prebuild": "npm run images:home-performance && npm run images:upload-variants && npm run images:manifest",
    "prestart": "npm run images:manifest",
    "prelint": "npm run images:manifest",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "seo:audit": "node ./scripts/audit-seo-merchant.mjs",
    "typecheck": "tsc --noEmit --pretty false",
    "test": "npm run lint && npm run typecheck",
    "deploy:dev": "./scripts/deploy-development.sh",
    "deploy:prod": "./scripts/deploy-production.sh"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.0.14",
    "framer-motion": "^12.24.10",
    "lucide-react": "^0.446.0",
    "next": "^16.2.6",
    "nprogress": "^0.2.0",
    "picomatch": "^2.3.2",
    "rc-slider": "^10.5.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-fast-marquee": "^1.6.5",
    "react-paginate": "^8.3.0",
    "react-slick": "^0.31.0",
    "sass": "^1.69.5",
    "sharp": "^0.34.5",
    "slick-carousel": "^1.8.1",
    "swiper": "^12.1.3"
  },
  "devDependencies": {
    "@types/node": "20.19.25",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@types/react-slick": "^0.23.13",
    "autoprefixer": "10.4.27",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.2.6",
    "postcss": "8.5.10",
    "react-image-zoom": "^1.3.1",
    "tailwindcss": "3.4.19",
    "typescript": "^5.4.0"
  },
  "overrides": {
    "postcss": "8.5.10"
  }
}
