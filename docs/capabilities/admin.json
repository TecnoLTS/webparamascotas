      "gateway": { "exposure": "tenant-api" },
      "data": { "fixture": "e2e-reporting-window", "assertions": ["dashboard-loads", "report-loads"] },
      "e2e": { "mode": "generic", "fixture": "e2e-reporting-window", "assertDb": true, "cleanup": true }
    },
    {
